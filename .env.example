# PVCIO Monitor — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# ── External auth API (First Love Center) ────────────────────────
VITE_AUTH_API_URL=https://your-auth-api-url

# ── Supabase ─────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# ── FLC Members GraphQL (church context resolution) ──────────────
# Default: https://dev-api-synago.firstlovecenter.com/graphql
# Override only if you need a different environment.
# VITE_MEMBER_GRAPHQL_URL=https://dev-api-synago.firstlovecenter.com/graphql

# ── Google Maps (place search in the GeoFencePicker) ─────────────
# Console: https://console.cloud.google.com/google/maps-apis/credentials
# Enable APIs: Maps JavaScript API + Places API.
# Restrictions:
#   • Application: HTTP referrers — add localhost:3000/*, your Vercel domain(s)
#   • API:        Maps JavaScript API, Places API only
# Set a daily billing cap as a safety net.
# Picker falls back to free Nominatim (OpenStreetMap) if this key is absent.
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
